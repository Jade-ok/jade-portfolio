---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description: "About Jade Lee — UBC Computer Science student.",
	title: "About",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-12">About</h1>
	<div class="prose prose-sm prose-cactus max-w-none">
		<p>I studied Journalism in Korea, and I loved it.</p>
		<p>
			When I came to Canada, I started thinking about Computer Science — that maybe it could open up
			new worlds for me, while still letting me reach back to the things I had always loved.
		</p>
		<p>
			That's how I found UBC's BCS program, which I think is quietly amazing. These days I spend my
			time complaining about exams with my friends, and then turning around and talking about how
			lucky we are to be studying here.
		</p>
		<p>
			You can find me on
			<a class="cactus-link" href="https://github.com/Jade-ok" target="_blank" rel="noreferrer"
				>GitHub</a
			>, or email me at
			<a class="cactus-link" href="mailto:jade.jinoklee@gmail.com">jade.jinoklee@gmail.com</a>.
		</p>
	</div>
</PageLayout>
