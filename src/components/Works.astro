---
const projects = [
  {
    num: "/01",
    title: "CareHandoff",
    desc: "Voice-powered handoff system for a nonprofit. FastAPI backend with Whisper + GPT-4o-mini turning audio into structured JSON across 50+ languages.",
    meta: "Hackathon · 2026",
    href: "#"
  },
  {
    num: "/02",
    title: "PrairieCalendar",
    desc: "Chrome Extension exporting PrairieTest exam schedules to Google Calendar & ICS. Live in the Web Store, serving 29 active users.",
    meta: "Side Project · 2025–",
    href: "#"
  },
  {
    num: "/03",
    title: "Smart Home Database",
    desc: "3NF-normalized relational schema across 20+ tables, with Node.js/Oracle REST endpoints supporting CRUD, aggregation, division & multi-table joins.",
    meta: "Academic · 2026",
    href: "#"
  }
];
---

<section class="block" id="works">
  <div class="container">
    <div class="label">
      <span class="bar"></span>
      <span class="num">02</span>
      <span>WORKS</span>
    </div>
    
    <h2 class="display">SELECTED<br />PRO<span class="accent">JECTS.</span></h2>
    
    <div class="works">
      {projects.map((p) => (
        <a class="work-row" href={p.href}>
          <div class="work-num">{p.num}</div>
          <div class="work-title">{p.title}</div>
          <div class="work-desc">{p.desc}</div>
          <div class="work-meta">
            <span>{p.meta}</span>
            <span class="work-arrow">→</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .block {
    padding: 160px 0;
    border-bottom: 1px solid color-mix(in srgb, var(--color-global-text) 12%, transparent);
    position: relative;
  }
  
  @media (max-width: 768px) {
    .block { padding: 100px 0; }
  }

  .container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 64px;
  }
  
  @media (max-width: 768px) {
    .container { padding: 0 24px; }
  }

  .label {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 32px;
  }

  .label .num {
    font-variant-numeric: tabular-nums;
  }

  .label .bar {
    display: inline-block;
    width: 48px;
    height: 1px;
    background: var(--color-accent);
  }

  .display {
    font-weight: 900;
    font-size: clamp(56px, 9vw, 100px);
    line-height: 0.92;
    letter-spacing: -0.04em;
    color: var(--color-global-text);
  }

  .display .accent {
    color: var(--color-accent);
  }

  .works {
    margin-top: 80px;
    border-top: 1px solid color-mix(in srgb, var(--color-global-text) 12%, transparent);
  }

  .work-row {
    position: relative;
    display: grid;
    grid-template-columns: 80px 1fr 1.6fr 200px;
    gap: 32px;
    align-items: center;
    padding: 36px 24px;
    border-bottom: 1px solid color-mix(in srgb, var(--color-global-text) 12%, transparent);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
  }

  .work-row::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.45s cubic-bezier(0.65, 0, 0.35, 1);
    z-index: 0;
  }

  .work-row:hover::before {
    transform: scaleX(1);
  }

  .work-row > * {
    position: relative;
    z-index: 1;
    transition: color 0.3s ease;
  }

  .work-row:hover,
  .work-row:hover * {
    color: #000 !important;
  }

  .work-num {
    font-size: 13px;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    color: var(--color-muted);
  }

  .work-title {
    font-size: 32px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--color-global-text);
  }

  .work-desc {
    font-size: 14px;
    line-height: 1.7;
    color: var(--color-muted);
  }

  .work-meta {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-muted);
    text-align: right;
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: flex-end;
  }

  .work-arrow {
    font-size: 24px;
    color: var(--color-accent);
  }

  @media (max-width: 900px) {
    .work-row {
      grid-template-columns: 60px 1fr;
      gap: 16px;
      padding: 28px 16px;
    }
    .work-row .work-desc,
    .work-row .work-meta {
      grid-column: 1 / -1;
    }
    .work-title {
      font-size: 24px;
    }
  }
</style>